# ============================================
# ChatBot WhatsApp - Lopez Tech
# Configuración de Variables de Entorno
# ============================================

# Servidor
PORT=3000
NODE_ENV=production

# yCloud API (WhatsApp Business API)
# Obtén tu API Key en: https://www.ycloud.com/console/#/app/developers/apikey
YCLOUD_API_KEY=tu_api_key_de_ycloud_aqui
YCLOUD_API_URL=https://api.ycloud.com/v2
YCLOUD_PHONE_NUMBER=57XXXXXXXXXX

# Token de verificación del webhook (lo configuras en yCloud)
YCLOUD_VERIFY_TOKEN=tu_token_de_verificacion

# Base de datos
DB_PATH=./data/chatbot.db

# Configuración del Negocio
BUSINESS_NAME=Lopez Tech
BUSINESS_LOCATION=Santa Marta, Colombia
BUSINESS_SCHEDULE_WEEKDAY=8:00-18:00
BUSINESS_SCHEDULE_SATURDAY=9:00-13:00
TIMEZONE=America/Bogota

# IA - Groq (opcional, para respuestas inteligentes)
# Obtén tu API Key en: https://console.groq.com
GROQ_API_KEY=gsk_tu_api_key_de_groq
GROQ_MODEL=llama-3.3-70b-versatile
